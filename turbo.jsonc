{
	"$schema": "https://v2-9-18.turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"//#check:biome": { "cache": false },
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
